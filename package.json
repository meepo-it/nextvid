{
  "name": "mkfast-template",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "check": "biome check",
    "lint": "biome check --write .",
    "format": "biome format --write .",
    "deploy": "pnpm run build && wrangler deploy",
    "postinstall": "pnpm run cf-typegen",
    "cf-typegen": "wrangler types --env-interface Env",
    "auth:schema:generate": "pnpm dlx @better-auth/cli@latest generate --yes --output src/db/auth.schema.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio:local": "drizzle-kit studio --config drizzle.config.local.ts",
    "db:studio:remote": "drizzle-kit studio --config drizzle.config.ts",
    "db:migrate:local": "wrangler d1 migrations apply $(tsx scripts/get-db-name.ts) --local",
    "db:migrate:remote": "wrangler d1 migrations apply $(tsx scripts/get-db-name.ts) --remote"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@beehiiv/sdk": "^0.1.9",
    "@cloudflare/vite-plugin": "^1.13.8",
    "@hookform/resolvers": "^5.2.2",
    "@libsql/client": "^0.15.15",
    "@react-email/components": "^1.0.7",
    "@t3-oss/env-core": "^0.13.10",
    "@tabler/icons-react": "^3.36.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/match-sorter-utils": "^8.19.4",
    "@tanstack/react-devtools": "^0.7.0",
    "@tanstack/react-form": "^1.0.0",
    "@tanstack/react-query": "^5.66.5",
    "@tanstack/react-query-devtools": "^5.84.2",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-router-devtools": "^1.132.0",
    "@tanstack/react-router-ssr-query": "^1.131.7",
    "@tanstack/react-start": "^1.132.0",
    "@tanstack/react-store": "^0.8.0",
    "@tanstack/react-table": "^8.21.2",
    "@tanstack/router-plugin": "^1.132.0",
    "@tanstack/store": "latest",
    "better-auth": "^1.4.12",
    "better-auth-harmony": "^1.2.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "embla-carousel-react": "^8.6.0",
    "html-react-parser": "^5.2.17",
    "input-otp": "^1.4.2",
    "marked": "^15.0.8",
    "nanoid": "^5.1.6",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.8",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-day-picker": "^9.13.2",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.1",
    "react-resizable-panels": "^4.6.4",
    "recharts": "2.15.4",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "resend": "^6.9.2",
    "shadcn": "^3.8.4",
